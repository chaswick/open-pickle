# Copy this file to config/local-secrets.env and fill in real values.
# This is the only local secrets file for the repo; the old root .env is obsolete.
# The live file is gitignored and excluded from Docker build context.

# Database
MYSQL_ROOT_PASSWORD=change-me
MYSQL_PASSWORD=change-me

# Mail
MAIL_HOST=smtp.example.invalid
MAIL_USERNAME=change-me
MAIL_PASSWORD=change-me

# Local app behavior
SESSION_COOKIE_SECURE=true
H2_CONSOLE_ENABLED=false

# Security
REMEMBER_ME_KEY=change-me
FHPB_MEETUPS_EMAIL_LINK_SECRET=change-me
FHPB_BOOTSTRAP_ADMIN_PASSWORD=

# External integrations
FHPB_PUBLIC_BASE_URL=http://localhost:8090
FHPB_OPENAI_API_KEY=

# Branding/operator overrides for private deployments
# FHPB_BRANDING_APP_NAME=Your Local Club
# FHPB_OPERATOR_NAME=Your Club LLC
# FHPB_OPERATOR_SUPPORT_EMAIL=support@your-club.example
# FHPB_OPERATOR_PUBLIC_URL=https://your-club.example
# FHPB_OPERATOR_DONATION_URL=https://your-club.example/support
# FHPB_BRANDING_LOGO_PATH=/images/landing/local-club-logo.png
# FHPB_BRANDING_SNAPSHOT_PATH=/images/landing/local-club-snapshot.png
# FHPB_BRANDING_FLAG_PATH=/images/local-club-flag.png

# Web Push (optional)
FHPB_PUSH_ENABLED=false
FHPB_PUSH_VAPID_SUBJECT=mailto:support@example.com
FHPB_PUSH_VAPID_PUBLIC_KEY=
FHPB_PUSH_VAPID_PRIVATE_KEY=
